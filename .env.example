# Required for the server to start
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/summit
JWT_SECRET=your-secret-key-change-in-production

# Optional – API base URL for the app (native / production web builds)
# EXPO_PUBLIC_API_URL=https://your-service.up.railway.app
#
# Vite dev (npm run web): by default /api proxies to http://localhost:3000 (run `npm run dev` for the API).
# If you set VITE_PROXY_TARGET to Railway, /api hits production — you must deploy the same backend code there
# or you will see old errors (e.g. Stripe). GET in a browser on /api/payments/checkout-session is not supported; use POST from the app.
# VITE_PROXY_TARGET=https://your-summit-service.up.railway.app
# Production web build uses full URL unless you set:
# VITE_API_URL=https://your-service.up.railway.app

# Optional – Stripe, Mailgun, Twilio, AWS S3, Firebase (server will warn if missing)
#
# Address: react-native-google-places-autocomplete (no /api/maps/autocomplete on your backend).
# Web (Vite): VITE_GOOGLE_MAPS_BROWSER_KEY=...  (+ GOOGLE_MAPS_* for local __places-proxy CORS helper in vite.config)
# Native: EXPO_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=... (same value as Google “browser” key; restrict by Android/iOS in Cloud Console)
# .env.local example:
# VITE_GOOGLE_MAPS_BROWSER_KEY=your-browser-key
# GOOGLE_MAPS_BROWSER_KEY=your-browser-key
# Stripe — server (Railway): required for Connect + PaymentIntents + webhooks
# STRIPE_SECRET_KEY=sk_test_...   MUST be Secret key (sk_...). Do NOT use Restricted key (rk_...) here.
# STRIPE_PUBLISHABLE_KEY=pk_test_...   Publishable key (pk_...) — safe in app / client
# STRIPE_WEBHOOK_SECRET=whsec_...       (from Developers → Webhooks → your endpoint → Signing secret)
#
# Australian ABN verification (ABR Lookup Web Services — free GUID from business.gov.au):
# ABR_LOOKUP_GUID=your-guid-from-abr-registration
# Public web app URL (password reset, verify-email, coordinator invite links). Must be where users open the React app — NOT the API-only host.
# WEB_APP_URL=http://localhost:5173
# WEB_APP_URL=https://your-summit-web-app.example.com
# Optional aliases: CLIENT_APP_URL, PUBLIC_APP_URL, FRONTEND_URL
#
# APP_URL=https://your-service.up.railway.app   (API / Stripe redirects — can differ from WEB_APP_URL)
#
# Client builds only (optional if you use publishable_key from POST /api/payments/create-intent):
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# React Native CLI builds: add the same key to `.env` as STRIPE_PUBLISHABLE_KEY (react-native-config) for Stripe Payment Sheet — rebuild after changing.
# Mailgun — required on the API server (npm run dev). Used by services/emailService.js for forgot-password, welcome, etc.
# MAILGUN_API_KEY=key-...   (Mailgun → Sending → Domain settings → API keys)
# MAILGUN_DOMAIN=mg.summitstaffing.com.au
# Production FROM must use your verified domain, e.g.:
# MAILGUN_FROM=Summit Staffing <noreply@mg.summitstaffing.com.au>
# Mailgun sandbox (testing only — can only send to authorized recipients in Mailgun dashboard):
# MAILGUN_DOMAIN=sandboxXXXX.mailgun.org
# MAILGUN_FROM=Summit Staffing <postmaster@sandboxXXXX.mailgun.org>
# MAILGUN_FROM_EMAIL=...   (alias for MAILGUN_FROM)
# Link in reset emails (optional; defaults to http://localhost:5173):
# WEB_APP_URL=http://localhost:5173
# WEB_APP_URL=https://summitstaffing.com.au
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Document uploads (recommended for production — PDF + images, CDN URLs for admin review)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=summit-staffing
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# FIREBASE_SERVER_KEY=
