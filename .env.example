# Required for the server to start
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/summit
JWT_SECRET=your-secret-key-change-in-production

# Optional – API base URL for the app (native / production web builds)
# EXPO_PUBLIC_API_URL=https://your-service.up.railway.app
#
# Vite dev (npm run web) — proxy /api to your Railway backend:
# VITE_PROXY_TARGET=https://your-summit-service.up.railway.app
# Production web build uses full URL unless you set:
# VITE_API_URL=https://your-service.up.railway.app

# Optional – Stripe, Mailgun, Twilio, AWS S3, Firebase (server will warn if missing)
#
# Address autocomplete GET /api/maps/autocomplete — keys stay on Railway (or below for local npm run web only).
# Railway / server:
# GOOGLE_MAPS_SERVER_KEY=...
# GOOGLE_MAPS_API_KEY=...
# GOOGLE_MAPS_BROWSER_KEY=...
# Local web (optional): copy same vars into .env.local — Vite dev server handles /api/maps/autocomplete
# without deploying that route, and keys are NOT exposed to the browser bundle.
# VITE_PROXY_TARGET=https://your-api.up.railway.app
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# FIREBASE_SERVER_KEY=
# APP_URL=http://localhost:3000
