# Required for the server to start
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/summit
JWT_SECRET=your-secret-key-change-in-production

# Optional – API base URL for the app (native / production web builds)
# EXPO_PUBLIC_API_URL=https://your-service.up.railway.app
#
# Vite dev (npm run web) — proxy /api to your Railway backend:
# VITE_PROXY_TARGET=https://your-summit-service.up.railway.app
# Production web build uses full URL unless you set:
# VITE_API_URL=https://your-service.up.railway.app

# Optional – Stripe, Mailgun, Twilio, AWS S3, Firebase (server will warn if missing)
#
# Address: react-native-google-places-autocomplete (no /api/maps/autocomplete on your backend).
# Web (Vite): VITE_GOOGLE_MAPS_BROWSER_KEY=...  (+ GOOGLE_MAPS_* for local __places-proxy CORS helper in vite.config)
# Native: EXPO_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=... (same value as Google “browser” key; restrict by Android/iOS in Cloud Console)
# .env.local example:
# VITE_GOOGLE_MAPS_BROWSER_KEY=your-browser-key
# GOOGLE_MAPS_BROWSER_KEY=your-browser-key
# Stripe — server (Railway): required for Connect + PaymentIntents + webhooks
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...   (same pk_... shown in Stripe Dashboard; safe to expose)
# STRIPE_WEBHOOK_SECRET=whsec_...       (from Developers → Webhooks → your endpoint → Signing secret)
# Public web app URL (used in password-reset and verify-email links). Must be the URL where users open the React app (e.g. Vite dev or production host), NOT the API-only host.
# WEB_APP_URL=http://localhost:5173
# WEB_APP_URL=https://your-summit-web-app.example.com
#
# APP_URL=https://your-service.up.railway.app   (API / Stripe redirects — can differ from WEB_APP_URL)
#
# Client builds only (optional if you use publishable_key from POST /api/payments/create-intent):
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# MAILGUN_API_KEY=key-...   (Sending → Domain settings → API keys in Mailgun)
# MAILGUN_DOMAIN=mg.yourdomain.com   (must be verified in Mailgun; sandbox domains only deliver to authorized recipients)
# MAILGUN_FROM=Summit Staffing <noreply@yourdomain.com>   (from-address must use your verified domain)
# MAILGUN_FROM_EMAIL=...   (alias — same as MAILGUN_FROM; supported for Railway-style naming)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# FIREBASE_SERVER_KEY=
# APP_URL=http://localhost:3000
